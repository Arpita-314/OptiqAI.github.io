import React, { useState, useRef, useEffect } from 'react';
import { FileText, Upload, MessageSquare, Loader2, Trash2, Brain, AlertCircle } from 'lucide-react';

const LocalDocQA = () => {
  const [documents, setDocuments] = useState([]);
  const [question, setQuestion] = useState('');
  const [answer, setAnswer] = useState('');
  const [loading, setLoading] = useState(false);
  const [modelLoading, setModelLoading] = useState(false);
  const [modelReady, setModelReady] = useState(false);
  const [progress, setProgress] = useState('');
  const pipelineRef = useRef(null);

  const loadModel = async () => {
    setModelLoading(true);
    setProgress('Loading Transformers.js library...');
    
    try {
      // Dynamically import Transformers.js
      const { pipeline } = await import('https://cdn.jsdelivr.net/npm/@xenova/transformers@2.17.1');
      
      setProgress('Initializing question-answering model (this may take a minute)...');
      
      // Load the Q&A pipeline
      pipelineRef.current = await pipeline('question-answering', 'Xenova/distilbert-base-cased-distilled-squad');
      
      setModelReady(true);
      setModelLoading(false);
      setProgress('Model ready!');
      
      setTimeout(() => setProgress(''), 2000);
    } catch (error) {
      alert('Error loading model: ' + error.message);
      setModelLoading(false);
      setProgress('');
    }
  };

  const handleFileUpload = async (e) => {
    const files = Array.from(e.target.files);
    
    for (const file of files) {
      if (file.type === 'text/plain' || file.name.endsWith('.txt') || file.name.endsWith('.md')) {
        const text = await file.text();
        setDocuments(prev => [...prev, {
          id: Date.now() + Math.random(),
          name: file.name,
          content: text,
          size: file.size
        }]);
      } else {
        alert('Please upload only .txt or .md files');
      }
    }
    
    e.target.value = '';
  };

  const handleAsk = async () => {
    if (!question.trim() || documents.length === 0) {
      alert('Please add documents and enter a question');
      return;
    }

    if (!modelReady) {
      alert('Please load the model first');
      return;
    }

    setLoading(true);
    setAnswer('');
    setProgress('Processing your question...');
    
    try {
      // Combine all documents as context
      const context = documents.map(doc => doc.content).join('\n\n');
      
      // Run the model
      const result = await pipelineRef.current(question, context);
      
      setAnswer(result.answer);
      setProgress('');
    } catch (error) {
      alert('Error: ' + error.message);
      setProgress('');
    } finally {
      setLoading(false);
    }
  };

  const removeDocument = (id) => {
    setDocuments(prev => prev.filter(doc => doc.id !== id));
  };

  const clearAll = () => {
    setDocuments([]);
    setQuestion('');
    setAnswer('');
  };

  return (
    <div className="min-h-screen bg-gradient-to-br from-slate-900 via-purple-900 to-slate-900 p-6">
      <div className="max-w-6xl mx-auto">
        <div className="text-center mb-8">
          <div className="flex items-center justify-center gap-3 mb-3">
            <Brain className="w-10 h-10 text-purple-400" />
            <h1 className="text-4xl font-bold text-white">Local Document Q&A</h1>
          </div>
          <p className="text-purple-200">AI-powered knowledge base running entirely in your browser</p>
        </div>

        {/* Model Status */}
        <div className="bg-white/10 backdrop-blur-lg rounded-xl p-6 mb-6 border border-white/20">
          <div className="flex items-center justify-between">
            <div className="flex items-center gap-3">
              <div className={`w-3 h-3 rounded-full ${modelReady ? 'bg-green-400' : 'bg-gray-400'} animate-pulse`} />
              <span className="text-white font-semibold">
                {modelReady ? 'Model Ready' : 'Model Not Loaded'}
              </span>
            </div>
            {!modelReady && !modelLoading && (
              <button
                onClick={loadModel}
                className="px-6 py-2 bg-purple-600 hover:bg-purple-700 text-white rounded-lg font-semibold transition-colors"
              >
                Load Model
              </button>
            )}
          </div>
          {(modelLoading || progress) && (
            <div className="mt-3 flex items-center gap-2 text-purple-200">
              <Loader2 className="w-4 h-4 animate-spin" />
              <span className="text-sm">{progress}</span>
            </div>
          )}
          {modelReady && (
            <div className="mt-3 flex items-center gap-2 text-green-300 text-sm">
              <AlertCircle className="w-4 h-4" />
              <span>Using DistilBERT for question answering</span>
            </div>
          )}
        </div>

        <div className="grid md:grid-cols-2 gap-6">
          {/* Documents Panel */}
          <div className="bg-white/10 backdrop-blur-lg rounded-xl p-6 border border-white/20">
            <div className="flex items-center justify-between mb-4">
              <h2 className="text-xl font-bold text-white flex items-center gap-2">
                <FileText className="w-5 h-5" />
                Documents ({documents.length})
              </h2>
              {documents.length > 0 && (
                <button
                  onClick={clearAll}
                  className="p-2 hover:bg-white/10 rounded-lg transition-colors text-red-400"
                  title="Clear all"
                >
                  <Trash2 className="w-4 h-4" />
                </button>
              )}
            </div>

            <label className="block mb-4">
              <div className="border-2 border-dashed border-purple-400 rounded-lg p-8 text-center hover:border-purple-300 transition-colors cursor-pointer bg-white/5">
                <Upload className="w-8 h-8 text-purple-400 mx-auto mb-2" />
                <p className="text-purple-200 text-sm mb-1">Click to upload documents</p>
                <p className="text-purple-300 text-xs">.txt or .md files</p>
                <input
                  type="file"
                  multiple
                  accept=".txt,.md"
                  onChange={handleFileUpload}
                  className="hidden"
                />
              </div>
            </label>

            <div className="space-y-2 max-h-64 overflow-y-auto">
              {documents.map(doc => (
                <div key={doc.id} className="bg-white/5 rounded-lg p-3 flex items-center justify-between">
                  <div className="flex-1 min-w-0">
                    <p className="text-white font-medium truncate">{doc.name}</p>
                    <p className="text-purple-300 text-xs">
                      {(doc.size / 1024).toFixed(1)} KB • {doc.content.length} chars
                    </p>
                  </div>
                  <button
                    onClick={() => removeDocument(doc.id)}
                    className="ml-2 p-1 hover:bg-white/10 rounded transition-colors text-red-400"
                  >
                    <Trash2 className="w-4 h-4" />
                  </button>
                </div>
              ))}
            </div>
          </div>

          {/* Q&A Panel */}
          <div className="bg-white/10 backdrop-blur-lg rounded-xl p-6 border border-white/20">
            <h2 className="text-xl font-bold text-white flex items-center gap-2 mb-4">
              <MessageSquare className="w-5 h-5" />
              Ask Questions
            </h2>

            <div className="space-y-4">
              <div>
                <label className="block text-purple-200 text-sm font-medium mb-2">
                  Your Question
                </label>
                <textarea
                  value={question}
                  onChange={(e) => setQuestion(e.target.value)}
                  placeholder="What would you like to know from your documents?"
                  className="w-full px-4 py-3 bg-white/5 border border-white/20 rounded-lg text-white placeholder-purple-300 focus:outline-none focus:ring-2 focus:ring-purple-500 min-h-24"
                />
              </div>

              <button
                onClick={handleAsk}
                disabled={loading || !modelReady || documents.length === 0}
                className="w-full py-3 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 disabled:from-gray-600 disabled:to-gray-600 text-white rounded-lg font-semibold transition-all flex items-center justify-center gap-2"
              >
                {loading ? (
                  <>
                    <Loader2 className="w-5 h-5 animate-spin" />
                    Processing...
                  </>
                ) : (
                  <>
                    <MessageSquare className="w-5 h-5" />
                    Ask Question
                  </>
                )}
              </button>

              {answer && (
                <div className="bg-gradient-to-r from-purple-500/20 to-pink-500/20 border border-purple-400/30 rounded-lg p-4">
                  <h3 className="text-purple-200 text-sm font-semibold mb-2">Answer:</h3>
                  <p className="text-white leading-relaxed">{answer}</p>
                </div>
              )}
            </div>
          </div>
        </div>

        {/* Info Section */}
        <div className="mt-6 bg-white/5 backdrop-blur-lg rounded-xl p-4 border border-white/10">
          <p className="text-purple-200 text-sm text-center">
            <strong>Privacy First:</strong> All processing happens locally in your browser. 
            No data is sent to any server. Model: DistilBERT (67M parameters)
          </p>
        </div>
      </div>
    </div>
  );
};

export default LocalDocQA;
